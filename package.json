{
  "name": "ferox",
  "icon": "icon.png",
  "displayName": "Ferox Hosting",
  "description": "Browse and edit Ferox Hosting server files directly from VS Code.",
  "version": "1.1.2",
  "publisher": "FeroxHosting",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ferox-Hosting/vscode-extension.git"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "activationEvents": [
    "onFileSystem:ferox",
    "onView:ferox.servers",
    "onUri"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ferox.signIn",
        "title": "Sign In",
        "category": "Ferox",
        "icon": "$(add)"
      },
      {
        "command": "ferox.signInOther",
        "title": "Sign In to Another Panel",
        "category": "Ferox"
      },
      {
        "command": "ferox.signOut",
        "title": "Sign Out",
        "category": "Ferox"
      },
      {
        "command": "ferox.openServer",
        "title": "Open Server Files",
        "category": "Ferox"
      },
      {
        "command": "ferox.powerAction",
        "title": "Server Power Action",
        "category": "Ferox"
      },
      {
        "command": "ferox.refreshServers",
        "title": "Refresh",
        "category": "Ferox",
        "icon": "$(refresh)"
      },
      {
        "command": "ferox.serverOpenFiles",
        "title": "Open Files",
        "category": "Ferox",
        "icon": "$(folder-opened)"
      },
      {
        "command": "ferox.serverPower",
        "title": "Power Action",
        "category": "Ferox",
        "icon": "$(pulse)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ferox",
          "title": "Ferox",
          "icon": "media/server.svg"
        }
      ]
    },
    "views": {
      "ferox": [
        {
          "id": "ferox.servers",
          "name": "Servers",
          "icon": "media/server.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "ferox.servers",
        "contents": "You are not signed in to a Ferox panel.\n[Sign In](command:ferox.signIn)",
        "when": "!ferox.signedIn"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "ferox.serverOpenFiles",
          "when": "false"
        },
        {
          "command": "ferox.powerAction",
          "when": "false"
        },
        {
          "command": "ferox.serverPower",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "ferox.signIn",
          "when": "view == ferox.servers",
          "group": "navigation@1"
        },
        {
          "command": "ferox.refreshServers",
          "when": "view == ferox.servers",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "ferox.serverOpenFiles",
          "when": "view == ferox.servers && viewItem == feroxServer",
          "group": "inline@1"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "npx tsc --noEmit && node esbuild.mjs --production",
    "package": "vsce package --no-dependencies --out dist/ferox.vsix",
    "code:install": "code --install-extension dist/ferox.vsix",
    "code:install-dev": "pnpm compile && pnpm package && pnpm code:install",
    "biome:validate": "biome format --css-parse-tailwind-directives=true && biome lint --css-parse-tailwind-directives=true && biome check",
    "biome:fix": "biome format --write --css-parse-tailwind-directives=true && biome lint --write --css-parse-tailwind-directives=true && biome check --write",
    "biome:fix-unsafe": "biome format --write --css-parse-tailwind-directives=true && biome lint --write --css-parse-tailwind-directives=true && biome check --write --unsafe"
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^20.19.42",
    "@types/vscode": "^1.120.0",
    "@types/ws": "^8.18.1",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  }
}
